# OpenRouter API Configuration
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Model Configuration (optional)
OPENCODE_MODEL=openrouter/anthropic/claude-3.5-sonnet

# Experiment Configuration (required)
# Specify which experiment to run (directory name in experiments/)
EXPERIMENT_NAME=example_sql_injection

# Reproducibility (optional)
# RANDOM_SEED=42
# DETERMINISTIC_RUNS=1
# N_ITERATIONS=10
# PARALLEL_WORKERS=1

# Logging (optional)
LOG_LEVEL=INFO
